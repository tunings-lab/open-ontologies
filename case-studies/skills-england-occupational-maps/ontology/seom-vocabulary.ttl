    rdfs:label "Approved occupation" .

<https://gov.tesseract.academy/id/seom/status/2> a seom:OccupationStatus ;
    rdfs:label "Occupational standard in development" .

<https://gov.tesseract.academy/id/seom/status/3> a seom:OccupationStatus ;
    rdfs:label "Potential occupational standard" .

<https://gov.tesseract.academy/id/seom/status/4> a seom:OccupationStatus ;
    rdfs:label "Occupational standard without apprenticeship" .

<https://gov.tesseract.academy/id/seom/technical-level/1> a seom:TechnicalLevel ;
    rdfs:label "Technical" .

<https://gov.tesseract.academy/id/seom/technical-level/2> a seom:TechnicalLevel ;
    rdfs:label "Higher Technical" .

<https://gov.tesseract.academy/id/seom/technical-level/3> a seom:TechnicalLevel ;
    rdfs:label "Professional" .

<https://gov.tesseract.academy/ns/seom> a owl:Ontology ;
    dct:created "2026-07-06"^^xsd:date ;
    dct:creator <https://gov.tesseract.academy/#organization> ;
    dct:description "An open, machine-readable ontology of the Skills England occupational maps: occupational standards and their routes, pathways and clusters, their Standard Occupational Classification (SOC 2010 and 2020) mappings, their apprenticeship and technical education products, their green-jobs classification, and the progression relationships between them. Built from a static snapshot of the Skills England Occupational Maps Public API." ;
    dct:license <https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/> ;
    dct:source <https://occupational-maps.skillsengland.education.gov.uk/public-api/> ;
    dct:title "Skills England Occupational Maps Ontology (SEOM)" ;
    rdfs:comment "Contains public sector information from Skills England licensed under the Open Government Licence v3.0." ;
    prov:wasDerivedFrom "Version: 1.0.0+3c45c9d34b8c9fe23b177828eae8cb57c9bf4abf, Last Updated: 09/04/2026 14:43:04" .

seom:atTechnicalLevel a owl:ObjectProperty ;
    rdfs:label "atTechnicalLevel" ;
    rdfs:comment "The technical level of this occupational standard." ;
    rdfs:domain seom:Occupation ;
    rdfs:range seom:TechnicalLevel .

seom:deliveredThrough a owl:ObjectProperty ;
    rdfs:label "deliveredThrough" ;
    rdfs:comment "A technical education product delivering this occupation." ;
    rdfs:domain seom:Occupation ;
    rdfs:range seom:Product .

seom:greenJobTitle a owl:DatatypeProperty ;
    rdfs:label "greenJobTitle" ;
    rdfs:comment "A typical job title flagged as a green job." .

seom:hasProductType a owl:ObjectProperty ;
    rdfs:label "hasProductType" ;
    rdfs:comment "The type of this technical education product." ;
    rdfs:domain seom:Product ;
    rdfs:range seom:ProductType .

seom:hasStatus a owl:ObjectProperty ;
    rdfs:label "hasStatus" ;
    rdfs:comment "The lifecycle status of this occupational standard." ;
    rdfs:domain seom:Occupation ;
    rdfs:range seom:OccupationStatus .

seom:inCluster a owl:ObjectProperty ;
    rdfs:label "inCluster" ;
    rdfs:comment "The cluster this occupational standard belongs to." ;
    rdfs:domain seom:Occupation ;
    rdfs:range seom:Cluster .

seom:inGreenTheme a owl:ObjectProperty ;
    rdfs:label "inGreenTheme" ;
    rdfs:comment "A green-jobs theme this occupation contributes to." ;
    rdfs:domain seom:Occupation ;
    rdfs:range seom:GreenTheme .

seom:inPathway a owl:ObjectProperty ;
    rdfs:label "inPathway" ;
    rdfs:comment "The pathway this occupational standard belongs to." ;
    rdfs:domain seom:Occupation ;
    rdfs:range seom:Pathway .

seom:inRoute a owl:ObjectProperty ;
    rdfs:label "inRoute" ;
    rdfs:comment "The route this occupational standard belongs to." ;
    rdfs:domain seom:Occupation ;
    rdfs:range seom:Route .

seom:involvedEmployers a owl:DatatypeProperty ;
    rdfs:label "involvedEmployers" ;
    rdfs:comment "Employers involved in defining the standard." .

seom:keyword a owl:DatatypeProperty ;
    rdfs:label "keyword" ;
    rdfs:comment "A keyword associated with the occupation." .

seom:level a owl:DatatypeProperty ;
    rdfs:label "level" ;
    rdfs:comment "The level of the occupational standard." .

seom:medianAnnualSalaryGBP a owl:DatatypeProperty ;
    rdfs:label "medianAnnualSalaryGBP" ;
    rdfs:comment "Median annual salary in GBP, where published." .

seom:overview a owl:DatatypeProperty ;
    rdfs:label "overview" ;
    rdfs:comment "The occupation overview text." .

seom:productCode a owl:DatatypeProperty ;
    rdfs:label "productCode" ;
    rdfs:comment "The product code of a technical education product (e.g. ST0118)." .

seom:progressesTo a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "progressesTo" ;
    rdfs:comment "An occupation a holder of this occupation can progress to." ;
    rdfs:domain seom:Occupation ;
    rdfs:range seom:Occupation .

seom:socMapping2010 a owl:ObjectProperty ;
    rdfs:label "socMapping2010" ;
    rdfs:comment "The SOC 2010 code this occupation maps to." ;
    rdfs:domain seom:Occupation ;
    rdfs:range seom:SOCConcept .

seom:socMapping2020 a owl:ObjectProperty ;
    rdfs:label "socMapping2020" ;
    rdfs:comment "The SOC 2020 code this occupation maps to." ;
    rdfs:domain seom:Occupation ;
    rdfs:range seom:SOCConcept .

seom:socVersion a owl:DatatypeProperty ;
    rdfs:label "socVersion" ;
    rdfs:comment "The SOC edition of a SOC concept (2010 or 2020)." .

seom:statusLastUpdated a owl:DatatypeProperty ;
    rdfs:label "statusLastUpdated" ;
    rdfs:comment "The date the standard's status was last updated." .

seom:stdCode a owl:DatatypeProperty ;
    rdfs:label "stdCode" ;
    rdfs:comment "The Skills England standard code (e.g. OCC0118)." .

seom:typicalJobTitle a owl:DatatypeProperty ;
    rdfs:label "typicalJobTitle" ;
    rdfs:comment "A typical job title for the occupation." .

seom:versionNo a owl:DatatypeProperty ;
    rdfs:label "versionNo" ;
    rdfs:comment "The version of the occupational standard." .

